diff --git a/whisper.cpp b/whisper.cpp
index b9e1ef2c..afe38f6c 100644
--- a/whisper.cpp
+++ b/whisper.cpp
@@ -6067,8 +6067,15 @@ int whisper_full_with_state(
             // [EXPERIMENTAL] Token-level timestamps with DTW
             {
                 const auto n_segments = state->result_all.size() - n_segments_before;
-                if (ctx->params.dtw_token_timestamps && n_segments) {
-                    const int n_frames = std::min(std::min(WHISPER_CHUNK_SIZE * 100, seek_delta), seek_end - seek);
+                // [PATCHED v1.5.5] Guard the experimental DTW token-timestamp pass
+                // against a window too short for its median filter (width 7). The
+                // pass asserts filter_width < a->ne[2], where a->ne[2] = n_frames/2,
+                // so a sub-~150ms final window (e.g. a hallucinated end-of-audio
+                // token like "Gracias .") aborts the whole process. Skipping DTW for
+                // such windows leaves those tokens with the non-DTW timestamps
+                // computed just above; real-speech windows are unaffected.
+                const int n_frames = std::min(std::min(WHISPER_CHUNK_SIZE * 100, seek_delta), seek_end - seek);
+                if (ctx->params.dtw_token_timestamps && n_segments && n_frames / 2 > 7) {
                     whisper_exp_compute_token_level_timestamps_dtw(
                             ctx, state, params, result_all.size() - n_segments, n_segments, seek, n_frames, 7, params.n_threads);
                 }
