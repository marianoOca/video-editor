{
  "name": "video-editor",
  "version": "0.5.0",
  "description": "Automated video editor with subtitles",
  "scripts": {
    "dev": "concurrently --kill-others -n studio,sidecar -c blue,green \"npx remotion studio\" \"python3 ../pipeline/sidecar.py\"",
    "dev:studio": "npx remotion studio",
    "render": "node render.mjs",
    "build": "node render.mjs",
    "postinstall": "patch-package && rm -rf node_modules/.cache/webpack"
  },
  "dependencies": {
    "@remotion/captions": "4.0.478",
    "@remotion/cli": "4.0.478",
    "@remotion/google-fonts": "4.0.478",
    "@remotion/install-whisper-cpp": "4.0.478",
    "@remotion/media": "4.0.478",
    "@remotion/player": "4.0.478",
    "@remotion/studio": "4.0.478",
    "remotion": "4.0.478",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
